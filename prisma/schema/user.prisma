model User {
    id           String        @id @unique @default(uuid())
    name         String
    email        String        @unique
    password     String
    activeStatus ACTIVE_STATUS @default(ACTIVE)
    role         ROLE          @default(USER)

    posts    Post[]
    profile  Profile?
    comments Comment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}
